{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "InterviewTrainingConnection": "Host=localhost;Port=5432;Database=interview_training_interview;UserId=postgres;Password=password"
  },
  "IdentityServerAuthentication": {
    "Authority": "https://localhost:5101/",
    "ApiName": "interview_training_interview"
  },
  "UserSync": {
    "ApiKey": "your-secure-api-key-here"
  },
  "UiUrls": [ "http://localhost:4200", "https://localhost:4200" ],
  "Serilog": {
    "Using": [ "Elastic.Serilog.Sinks" ],
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [
      {
        "Name": "Elasticsearch",
        "Args": {
          "bootstrapMethod": "Silent",
          "nodes": [ "http://localhost:9200" ],
          "dataStream": "interviewtraining-api-logs"
        }
      }
    ]
  }
}
