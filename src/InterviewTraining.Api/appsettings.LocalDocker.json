{
  "ConnectionStrings": {
    "InterviewTrainingConnection": "Host=postgres;Port=5432;Database=interview_training_interview_prod;UserId=postgres;Password=password"
  },
  "IdentityServerAuthentication": {
    "Authority": "https://interview-training.site:5108/",
    "ApiName": "interview_training_interview"
  },
  "UserSync": {
    "ApiKey": "your-secure-api-key-here"
  },
  "UiUrls": [ "http://interview-training.site", "https://interview-training.site" ],
  "Serilog": {
    "Using": [ "Elastic.Serilog.Sinks" ],
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [
      {
        "Name": "Elasticsearch",
        "Args": {
          "bootstrapMethod": "Silent",
          "nodes": [ "http://elasticsearch:9200" ],
          "dataStream": "interviewtraining-api-prod-logs"
        }
      }
    ]
  }
}

